{
    "name": "sherlock-chain-analysis",
    "version": "1.0.0",
    "description": "Bitcoin chain-analysis engine for the Summer of Bitcoin 2026 Week 3 challenge.",
    "type": "module",
    "engines": {
        "node": "20.x"
    },
    "scripts": {
        "setup": "bash setup.sh",
        "cli": "node src/cli.js",
        "web": "node src/web/server.js",
        "build:web": "vite build --config src/web/vite.config.js",
        "vercel-build": "npm run build:web",
        "dev:web": "vite --config src/web/vite.config.js",
        "test": "node --test --test-reporter=spec",
        "test:parser": "node --test src/parser/blockParser.test.js"
    },
    "dependencies": {
        "bitcoinjs-lib": "^6.1.6",
        "commander": "^12.1.0",
        "express": "^4.19.2",
        "tiny-secp256k1": "^2.2.3"
    },
    "devDependencies": {
        "vite": "^5.2.0",
        "@vitejs/plugin-react": "^4.3.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    }
}