{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npm run build:web",
    "outputDirectory": "src/web/dist",
    "functions": {
        "api/index.js": {
            "runtime": "nodejs20.x",
            "maxDuration": 60
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}